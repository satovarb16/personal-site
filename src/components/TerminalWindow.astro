---
interface Props {
  /** Text shown centered in the title bar (e.g. "santiago_tovar — zsh"). */
  title?: string;
}

const { title } = Astro.props;
---

<!-- A faux terminal window: a chrome bar with Dracula traffic lights over a
     body slot. Elevation climbs page (ink) → body (panel) → title bar (raised),
     so the window reads as floating without loud borders. -->
<div
  class="overflow-hidden rounded-[var(--r-xl)] border border-[var(--rule)] bg-[var(--console-panel)] shadow-[0_18px_50px_-24px_rgba(0,0,0,0.65)]"
>
  <div class="relative flex h-9 items-center border-b border-[var(--rule)] bg-[var(--console-raised)] px-4">
    <span class="flex items-center gap-2" aria-hidden="true">
      <span class="h-3 w-3 rounded-full bg-[var(--dracula-red)]"></span>
      <span class="h-3 w-3 rounded-full bg-[var(--dracula-yellow)]"></span>
      <span class="h-3 w-3 rounded-full bg-[var(--dracula-green)]"></span>
    </span>
    {
      title && (
        <span class="pointer-events-none mx-auto font-mono text-[11px] tracking-tight text-[var(--print-faint)]">
          {title}
        </span>
      )
    }
  </div>

  <div class="p-6 md:p-8">
    <slot />
  </div>
</div>
