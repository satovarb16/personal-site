---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const interactive = Boolean(project.link);
---

<article
  class={`rounded-[var(--r-lg)] border border-[var(--rule)] bg-[var(--console-panel)] p-6 flex flex-col gap-5 transition-colors ${interactive ? "hover:border-[var(--rule-bright)] hover:bg-[var(--console-raised)] cursor-pointer group" : ""}`}
  data-skills={project.skills.join(",")}
  data-link={project.link}
>
  <!-- Header: title leads, role + period read as machine metadata -->
  <div class="flex items-start justify-between gap-4">
    <div class="flex flex-col gap-1.5 min-w-0">
      <h3 class="font-semibold text-[15px] text-[var(--signal-alt)] leading-snug group-hover:text-[var(--signal-alt-bright)] transition-colors">
        {project.title}
      </h3>
      <p class="font-mono text-[11px] text-[var(--print-dim)] tracking-tight">{project.role}</p>
    </div>
    <div class="flex flex-col items-end gap-1.5 shrink-0">
      {project.featured && (
        <span
          class="text-[var(--signal-bright)] leading-none text-[13px]"
          title="Featured project"
          aria-label="Featured project"
        >★</span>
      )}
      {project.link && (
        <span class="inline-flex items-center gap-1 font-mono text-[10px] uppercase tracking-widest text-[var(--signal-bright)] opacity-0 group-hover:opacity-100 transition-opacity">
          {project.linkLabel ?? "open"}
          <span aria-hidden="true">↗</span>
        </span>
      )}
      <span class="font-mono text-[10px] text-[var(--print-faint)] whitespace-nowrap tracking-tight">{project.period}</span>
    </div>
  </div>

  <!-- Description -->
  <p class="text-sm text-[var(--print-default)] leading-relaxed">{project.description}</p>

  <!-- Highlights: structured log lines — a mono caret marks each entry -->
  <ul class="flex flex-col gap-2.5">
    {project.highlights.map((h) => (
      <li class="flex items-start gap-2.5 text-[13px] text-[var(--print-dim)] leading-relaxed">
        <span class="mt-0.5 shrink-0 font-mono text-[11px] text-[var(--signal-bright)] opacity-60 select-none">→</span>
        <span>{h}</span>
      </li>
    ))}
  </ul>

  <!-- Skills: recessed tag well, separated by a quiet seam -->
  <div class="flex flex-wrap gap-1.5 mt-auto pt-4 border-t border-[var(--rule-faint)]">
    {
      project.skills.map((skill) => (
        <span class="px-2 py-0.5 rounded-[var(--r-sm)] text-[11px] bg-[var(--console-inset)] border border-[var(--rule-faint)] text-[var(--print-faint)] font-mono tracking-tight">
          {skill}
        </span>
      ))
    }
  </div>
</article>

<script>
  document.querySelectorAll<HTMLElement>("article[data-link]").forEach((card) => {
    const link = card.dataset.link;
    if (link) {
      card.addEventListener("click", () => window.open(link, "_blank", "noopener,noreferrer"));
    }
  });
</script>
