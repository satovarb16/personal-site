---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Timeline from "../components/Timeline.astro";
import Contact from "../components/Contact.astro";
import TerminalWindow from "../components/TerminalWindow.astro";
import { projects, filterSkills } from "../data/projects";
import { certifications } from "../data/certifications";
import { Image } from "astro:assets";
import profilePhoto from "../assets/profile.jpg";

// Stack grouped by intent — the machine layer reads as labeled rows of a
// config, not an undifferentiated tag soup.
const stackGroups = [
  { label: "languages", items: ["Python", "JavaScript", "C++"] },
  { label: "agentic", items: ["Claude Code", "AI Agents", "MCP", "Ollama"] },
  { label: "web", items: ["React", "Flask", "REST APIs"] },
  { label: "data", items: ["PostgreSQL", "Supabase"] },
  { label: "ops", items: ["Git", "Linux", "CI/CD", "TDD", "SDD"] },
  // Spoken languages — labeled "spoken" so it never collides with the
  // programming "languages" group above.
  { label: "spoken", items: ["English (Fluent)", "Spanish (Native)", "Italian (Fluent)"] },
];
---

<Layout title="Santiago Tovar — AI Engineer">
  <!-- ============================ HERO ============================
       The focal point. The one thing a recruiter must feel in 10s:
       this person ships real agentic systems. Name dominates; a live
       process line declares availability the way a daemon reports up. -->
  <section id="about" class="pt-16 pb-14 md:pt-20 md:pb-16 border-b border-[var(--rule-faint)]">
    <!-- The about is one terminal window laid out as an L: the name block sits
         top-left beside the portrait (top-right), and the bio + actions run the
         full width along the bottom — the foot of the L. -->
    <TerminalWindow title="santiago_tovar — zsh">
      <div class="grid grid-cols-1 gap-x-10 gap-y-8 md:grid-cols-[1fr_auto]">
        <!-- Top-left: status, name, role — centered against the taller portrait -->
        <div class="flex flex-col gap-6 md:col-start-1 md:row-start-1 md:self-center">
          <!-- Live process line -->
          <div class="inline-flex items-center gap-2.5 self-start rounded-full border border-[var(--live-wash)] bg-[var(--live-wash)] pl-2 pr-3 py-1">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--live)] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--live)]"></span>
            </span>
            <span class="font-mono text-[11px] text-[var(--live)] tracking-tight">
              status: open to AI engineering roles
            </span>
          </div>

          <div class="flex flex-col gap-3">
            <div class="flex flex-col gap-2">
              <!-- Hero framed as a terminal session: the name is the output of `WhoAmI` -->
              <p class="prompt-label">WhoAmI</p>
              <h1 class="text-[2.75rem] md:text-6xl font-bold text-[var(--print-bright)] leading-[1.04] tracking-tight">
                Santiago Tovar
              </h1>
            </div>
            <p class="text-sm font-medium text-[var(--signal-bright)] tracking-tight">
              AI Engineer<span class="text-[var(--print-faint)] mx-1.5">·</span>Full-Stack Developer
            </p>
          </div>
        </div>

        <!-- Top-right: the portrait as a nested image-viewer window -->
        <div class="md:col-start-2 md:row-start-1 justify-self-center md:justify-self-end">
          <TerminalWindow title="graduation.jpg" bodyClass="p-0 overflow-hidden">
            <Image
              src={profilePhoto}
              alt="Santiago Tovar"
              width={416}
              height={512}
              quality={95}
              loading="eager"
              class="block w-52 h-72 md:w-64 md:h-80 object-cover"
              style="object-position: 50% 33%; transform: scale(1.25); transform-origin: center 33%;"
            />
          </TerminalWindow>
        </div>

        <!-- Foot of the L: bio + actions, spanning the full width -->
        <div class="flex flex-col gap-7 md:col-span-2 md:row-start-2">
          <!-- The blinking cursor trails the bio: the story is still being written. -->
          <p class="text-[15px] text-[var(--print-default)] leading-[1.8]">
            Computer Engineering grad (UF '26) who ships real AI systems — directing Claude Code and
            autonomous sub-agents with spec-driven (SDD) and test-driven (TDD) workflows, from spec to
            production. Built a production MCP server for job-search automation and a live restaurant site,
            both in active use. Full-stack foundation in Python, React, Flask, and databases.<span
              class="cursor-blink ml-1 font-normal text-[var(--signal-bright)]"
              aria-hidden="true">▌</span
            >
          </p>

          <div class="flex flex-wrap items-center gap-2.5">
            <a
              href="mailto:satovarb@gmail.com"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--r-md)] bg-[var(--signal)] text-[var(--console-ink)] text-sm font-semibold hover:bg-[var(--signal-bright)] transition-colors"
            >
              Get in touch
            </a>
            <a
              href="https://www.linkedin.com/in/santiagotovarbrousset"
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-[var(--r-md)] border border-[var(--rule)] text-sm text-[var(--print-default)] hover:text-[var(--print-bright)] hover:border-[var(--rule-bright)] transition-colors"
            >
              LinkedIn
            </a>
            <a
              href="https://github.com/satovarb16"
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-[var(--r-md)] border border-[var(--rule)] text-sm text-[var(--print-default)] hover:text-[var(--print-bright)] hover:border-[var(--rule-bright)] transition-colors"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </TerminalWindow>
  </section>

  <!-- ============================ STACK ============================
       Labeled rows, like a printed config block. Each group is a key,
       its tools are the value. -->
  <section id="skills" class="py-11 border-b border-[var(--rule-faint)]">
    <p class="prompt-label mb-6">stack --list</p>
    <dl class="flex flex-col divide-y divide-[var(--rule-faint)]">
      {
        stackGroups.map((group) => (
          <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4 py-3 first:pt-0 last:pb-0">
            <dt class="font-mono text-[14px] text-[var(--signal-alt)] uppercase tracking-widest w-28 shrink-0 pt-1 opacity-80">
              {group.label}
            </dt>
            <dd class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="px-2.5 py-1 rounded-[var(--r-sm)] text-xs border border-[var(--rule)] text-[var(--print-dim)] bg-[var(--console-inset)] font-mono tracking-tight">
                  {item}
                </span>
              ))}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- ============================ PROJECTS ============================ -->
  <section id="projects" class="py-16 border-b border-[var(--rule-faint)]">
    <div class="flex items-center justify-between mb-7">
      <p class="prompt-label">
        projects
        <span class="text-[var(--print-faint)]">--count</span>
        <span class="text-[var(--signal-bright)] ml-1">{projects.length}</span>
      </p>
    </div>

    <!-- Filter: pills framed as active query state -->
    <div class="flex flex-wrap gap-2 mb-7" id="filter-bar">
      <button
        class="filter-btn px-3 py-1 rounded-[var(--r-sm)] text-xs font-mono tracking-tight border border-[var(--rule-accent)] text-[var(--signal-bright)] bg-[var(--signal-wash)] transition-colors"
        data-filter="all"
      >
        all
      </button>
      {
        filterSkills.map((skill) => (
          <button
            class="filter-btn px-3 py-1 rounded-[var(--r-sm)] text-xs font-mono tracking-tight border border-[var(--rule)] text-[var(--print-dim)] hover:border-[var(--rule-bright)] hover:text-[var(--print-default)] bg-[var(--console-inset)] transition-colors"
            data-filter={skill}
          >
            {skill}
          </button>
        ))
      }
    </div>

    <div class="grid gap-4 md:grid-cols-2" id="projects-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- ============================ CERTIFICATIONS ============================ -->
  <section id="certifications" class="py-16 border-b border-[var(--rule-faint)]">
    <div class="flex items-center justify-between mb-7">
      <p class="prompt-label">
        certifications
        <span class="text-[var(--print-faint)]">--count</span>
        <span class="text-[var(--signal-bright)] ml-1">{certifications.length}</span>
      </p>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        certifications.map((cert) => (
          <div class="rounded-[var(--r-lg)] border border-[var(--rule)] bg-[var(--console-panel)] p-5 flex flex-col gap-2 hover:border-[var(--rule-bright)] hover:bg-[var(--console-raised)] transition-colors">
            <p class="font-mono text-[10px] text-[var(--signal-alt)] uppercase tracking-widest opacity-80">{cert.issuer}</p>
            <p class="text-[15px] font-medium text-[var(--print-bright)] leading-snug">{cert.title}</p>
            <p class="text-[11px] text-[var(--print-faint)] mt-auto font-mono">{cert.year}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============================ TIMELINE + CONTACT ============================ -->
  <Timeline />
  <Contact />
</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = Array.from(document.querySelectorAll<HTMLElement>("#projects-grid article"));

  const ACTIVE = ["border-[var(--rule-accent)]", "text-[var(--signal-bright)]", "bg-[var(--signal-wash)]"];
  const IDLE = ["border-[var(--rule)]", "text-[var(--print-dim)]", "bg-[var(--console-inset)]"];

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const EASE = "cubic-bezier(0.22, 1, 0.36, 1)";

  const matches = (card: HTMLElement, filter: string) => {
    const skills = card.dataset.skills?.split(",") ?? [];
    return filter === "all" || skills.includes(filter);
  };
  const isVisible = (card: HTMLElement) => card.style.display !== "none";

  function applyFilter(filter: string) {
    // FIRST — snapshot where the currently-visible cards sit.
    const firstRects = new Map<HTMLElement, DOMRect>();
    cards.forEach((card) => {
      if (isVisible(card)) firstRects.set(card, card.getBoundingClientRect());
    });

    const leaving = cards.filter((card) => isVisible(card) && !matches(card, filter));

    // Reflow the survivors and reveal the newcomers once any exit fade is done.
    const settle = () => {
      cards.forEach((card) => (card.style.display = matches(card, filter) ? "" : "none"));

      cards.forEach((card) => {
        if (!matches(card, filter)) return;
        const first = firstRects.get(card);
        const last = card.getBoundingClientRect();
        if (first) {
          // Survivor — slide from its old slot to the new one (FLIP). The slide
          // is real movement, so it is skipped under reduced motion.
          if (reduceMotion) return;
          const dx = first.left - last.left;
          const dy = first.top - last.top;
          if (dx || dy) {
            card.animate(
              [{ transform: `translate(${dx}px, ${dy}px)` }, { transform: "translate(0, 0)" }],
              { duration: 420, easing: EASE },
            );
          }
        } else {
          // Newcomer — fade in (plus a slight scale when motion is allowed).
          card.animate(
            reduceMotion
              ? [{ opacity: 0 }, { opacity: 1 }]
              : [
                  { opacity: 0, transform: "scale(0.96)" },
                  { opacity: 1, transform: "scale(1)" },
                ],
            { duration: 360, easing: EASE },
          );
        }
      });
    };

    if (leaving.length) {
      // Exit is an opacity fade — safe under reduced motion — with a touch of
      // scale only when motion is allowed.
      const exits = leaving.map(
        (card) =>
          card.animate(
            reduceMotion
              ? [{ opacity: 1 }, { opacity: 0 }]
              : [
                  { opacity: 1, transform: "scale(1)" },
                  { opacity: 0, transform: "scale(0.96)" },
                ],
            { duration: 180, easing: "ease-in" },
          ).finished,
      );
      Promise.allSettled(exits).then(settle);
    } else {
      settle();
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach((b) => {
        b.classList.remove(...ACTIVE);
        b.classList.add(...IDLE);
      });
      btn.classList.remove(...IDLE);
      btn.classList.add(...ACTIVE);

      applyFilter(filter);
    });
  });
</script>
