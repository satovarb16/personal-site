---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sorted = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<Layout title="Blog — Santiago Tovar">
  <section class="py-16">
    <div class="mb-11">
      <p class="prompt-label mb-4">blog --all</p>
      <h1 class="text-4xl font-bold text-[var(--print-bright)] mb-3 leading-tight">Blog</h1>
      <p class="text-sm text-[var(--print-default)] max-w-md leading-relaxed">
        What I'm building, studying, and thinking about. Career direction, tools, and day-to-day learning.
      </p>
    </div>

    {
      sorted.length === 0 ? (
        <div class="rounded-[var(--r-lg)] border border-dashed border-[var(--rule)] bg-[var(--console-inset)] p-12 text-center">
          <p class="font-mono text-xs text-[var(--print-faint)]">
            <span class="text-[var(--print-dim)]">$ ls posts/</span>
            <span class="block mt-2">no posts yet — check back soon</span>
          </p>
        </div>
      ) : (
        <ul class="flex flex-col gap-3">
          {sorted.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group flex flex-col gap-2 rounded-[var(--r-lg)] border border-[var(--rule)] bg-[var(--console-panel)] p-5 hover:border-[var(--rule-bright)] hover:bg-[var(--console-raised)] transition-colors"
              >
                <div class="flex items-start justify-between gap-4">
                  <h2 class="font-semibold text-[15px] text-[var(--print-bright)] group-hover:text-[var(--signal-bright)] transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  <time class="font-mono text-[10px] text-[var(--print-faint)] shrink-0 pt-1 tracking-tight">
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </div>
                {post.data.description && (
                  <p class="text-sm text-[var(--print-default)] leading-relaxed">{post.data.description}</p>
                )}
                {post.data.tags.length > 0 && (
                  <div class="flex gap-1.5 mt-1">
                    {post.data.tags.map((tag) => (
                      <span class="px-2 py-0.5 rounded-[var(--r-sm)] text-[11px] bg-[var(--console-inset)] border border-[var(--rule-faint)] text-[var(--print-faint)] font-mono tracking-tight">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
