---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;
const dateObj = new Date(String(pubDate).replace(/-/g, "/"));
const formattedDate = dateObj.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} — Santiago Tovar`} description={description}>
  <article class="py-16 max-w-2xl">
    <header class="mb-12">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 font-mono text-[11px] text-[var(--print-dim)] hover:text-[var(--signal-bright)] transition-colors mb-8"
      >
        <span class="text-[var(--print-faint)]">cd</span> ../blog
      </a>
      <h1 class="text-[2rem] md:text-[2.5rem] font-bold text-[var(--print-bright)] mb-5 leading-[1.1]">{title}</h1>
      <div class="flex flex-wrap items-center gap-3">
        <time datetime={dateObj.toISOString()} class="font-mono text-[11px] text-[var(--print-faint)] tracking-tight">
          {formattedDate}
        </time>
        {tags.length > 0 && (
          <div class="flex gap-1.5">
            {tags.map((tag) => (
              <span class="px-2 py-0.5 rounded-[var(--r-sm)] text-[11px] bg-[var(--console-inset)] border border-[var(--rule-faint)] text-[var(--print-faint)] font-mono tracking-tight">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose prose-invert prose-purple max-w-none
      prose-headings:text-[var(--print-bright)] prose-headings:font-semibold prose-headings:tracking-tight
      prose-p:text-[var(--print-default)] prose-p:leading-relaxed
      prose-a:text-[var(--signal-bright)] prose-a:no-underline hover:prose-a:underline
      prose-code:text-[var(--signal-bright)] prose-code:text-sm prose-code:font-mono
      prose-pre:bg-[var(--console-inset)] prose-pre:border prose-pre:border-[var(--rule)] prose-pre:rounded-[var(--r-lg)]
      prose-strong:text-[var(--print-bright)] prose-strong:font-semibold
      prose-li:text-[var(--print-default)]
      prose-blockquote:border-l-2 prose-blockquote:border-[var(--rule-accent)] prose-blockquote:pl-4 prose-blockquote:text-[var(--print-dim)]">
      <slot />
    </div>
  </article>
</Layout>
