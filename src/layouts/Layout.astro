---
import "../styles/global.css";
import { Font } from "astro:assets";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Santiago Tovar — AI Engineer & Full-Stack Developer" } = Astro.props;

const currentPath = Astro.url.pathname;
const onHome = currentPath === "/";

// `active` here is only the initial (server-rendered) state. On the home page
// the active indicator is taken over by a client-side scroll-spy (see the
// script at the end of <body>) because in-page anchor clicks don't re-render.
// Order mirrors the section order on the page.
const navLinks = [
  { href: "/#projects", label: "projects", section: "projects", active: onHome },
  { href: "/#certifications", label: "certs", section: "certifications", active: false },
  { href: "/#timeline", label: "timeline", section: "timeline", active: false },
  { href: "/#contact", label: "contact", section: "contact", active: false },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-jetbrains-mono" preload />
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--rule)] bg-[var(--console-ink)]/80 backdrop-blur-xl">
      <div class="mx-auto max-w-5xl px-6 h-14 flex items-center justify-between">
        <!-- Brand as a shell prompt — the operator's handle -->
        <a
          href="/"
          class="group flex shrink-0 items-center gap-2 font-mono text-[13px] tracking-tight text-[var(--print-bright)] transition-colors"
        >
          <span class="text-[var(--signal-bright)] opacity-80 group-hover:opacity-100 transition-opacity">~</span>
          <span>santiago_tovar</span>
        </a>

        <!-- Nav links framed as terminal flags. The row scrolls horizontally
             (scrollbar hidden) so it never overflows the bar on small screens. -->
        <div class="flex min-w-0 items-center gap-0.5 overflow-x-auto font-mono text-[12px] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                data-nav={link.section}
                class={`shrink-0 whitespace-nowrap px-2.5 py-1 rounded-[var(--r-sm)] tracking-tight transition-colors ${
                  link.active
                    ? "text-[var(--signal-bright)] bg-[var(--signal-wash)]"
                    : "text-[var(--print-dim)] hover:text-[var(--print-default)] hover:bg-[var(--rule-faint)]"
                }`}
              >
                <span class="text-[var(--print-faint)]">/</span>
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-5xl px-6 pt-14">
      <slot />
    </main>

    <footer class="mt-28 border-t border-[var(--rule-faint)] py-8">
      <div class="mx-auto max-w-5xl px-6 flex items-center justify-between font-mono text-[11px] text-[var(--print-faint)]">
        <span>
          <span class="text-[var(--signal-bright)] opacity-70">$</span>
          <span class="ml-1.5">santiago_tovar</span>
          <span class="text-[var(--print-faint)]"> © {new Date().getFullYear()}</span>
        </span>
        <span class="flex items-center gap-1.5">
          <span class="text-[var(--print-faint)]">built_with</span>
          <span class="text-[var(--print-dim)]">astro</span>
        </span>
      </div>
    </footer>

    <script>
      // Active-section indicator for the in-page nav. Runs only on pages that
      // actually contain the sections (the home page). Anchor clicks scroll but
      // don't re-render, so the active state must be managed client-side.
      const ACTIVE = ["text-[var(--signal-bright)]", "bg-[var(--signal-wash)]"];
      const IDLE = [
        "text-[var(--print-dim)]",
        "hover:text-[var(--print-default)]",
        "hover:bg-[var(--rule-faint)]",
      ];

      const items = new Map<string, HTMLAnchorElement>();
      document
        .querySelectorAll<HTMLAnchorElement>("nav a[data-nav]")
        .forEach((a) => a.dataset.nav && items.set(a.dataset.nav, a));

      // Only the in-page sections present on this page take part in scroll-spy.
      const spySections = ["projects", "certifications", "timeline", "contact"].filter(
        (id) => document.getElementById(id),
      );

      if (spySections.length) {
        const setActive = (section: string) => {
          for (const id of spySections) {
            const link = items.get(id);
            if (!link) continue;
            const on = id === section;
            link.classList.remove(...(on ? IDLE : ACTIVE));
            link.classList.add(...(on ? ACTIVE : IDLE));
          }
        };

        // Instant feedback on click — don't wait for the scroll to settle.
        for (const id of spySections) {
          items.get(id)?.addEventListener("click", () => setActive(id));
        }

        // Keep it in sync while the user scrolls manually.
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) setActive(entry.target.id);
            }
          },
          { rootMargin: "-15% 0px -70% 0px", threshold: 0 },
        );
        for (const id of spySections) {
          const el = document.getElementById(id);
          if (el) observer.observe(el);
        }
      }
    </script>
  </body>
</html>
